PORT=3001
RAG_SERVICE_URL=http://localhost:8000
CORS_ORIGIN=http://localhost:3000

# Groq configuration
GROQ_API_KEY=replace_with_your_groq_key
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODEL=qwen/qwen3-32b

# Optional comma-separated allowlist shown in /ollama/api/tags fallback
GROQ_MODELS=llama-3.1-8b-instant,qwen/qwen3-32b,llama-3.3-70b-versatile

# Rate-limit-aware output controls
GROQ_MAX_TOKENS=768
GROQ_TEMPERATURE=0.2
AI_RPM_LIMIT=25
